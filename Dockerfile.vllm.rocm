FROM vllm/vllm-openai-rocm:v0.20.0

# Ensure miopen cache directory exists in the container
RUN mkdir -p /root/miopen

# Set environment variables for ROCm compatibility
ENV VLLM_USE_ROCM=1
ENV MIOPEN_USER_DB_PATH=/root/miopen
ENV FLASH_ATTENTION_TRITON_AMD_ENABLE=1
ENV GPU_MAX_HW_QUEUES=1
ENV GPU_KEEPALIVE_INTERVAL=15
ENV MIOPEN_FIND_MODE=FAST
ENV VLLM_ROCM_USE_AITER=1

# Install vllm-omni specific dependencies
COPY vllm-omni/requirements/rocm.txt /tmp/rocm.txt
COPY vllm-omni/requirements/common.txt /tmp/common.txt
RUN pip install -r /tmp/rocm.txt

# The command is provided in docker-compose.yml, but we can set a default here
CMD ["python3", "-m", "vllm_omni.entrypoints.openai.api_server", "--model", "Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice", "--pipeline-parallel-size", "1", "--host", "0.0.0.0", "--port", "8009", "--gpu-memory-utilization", "0.3", "--enforce-eager", "--max-model-len", "4096"]
